# ==============================================================================
#  AI Bookkeeping Agent Platform — Environment Variables Template
#  Copy this file to `.env` and fill in your real credentials.
#  NEVER commit `.env` to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_NAME="AI Bookkeeping Agent Platform"
APP_VERSION="1.0.0"
ENVIRONMENT="development"       # development | staging | production
DEBUG=false
API_V1_PREFIX="/api/v1"

# ------------------------------------------------------------------------------
# Security
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------------------------
SECRET_KEY="CHANGE_ME_GENERATE_A_STRONG_RANDOM_SECRET"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------------------------------------
# Xero API  (OAuth 2.0 + PKCE)
# Register your app at: https://developer.xero.com/app/manage
# Scopes:  openid profile email accounting.transactions accounting.contacts offline_access
# ------------------------------------------------------------------------------
XERO_BASE_URL="https://api.xero.com"
XERO_AUTH_URL="https://login.xero.com/identity/connect/authorize"
XERO_TOKEN_URL="https://identity.xero.com/connect/token"
XERO_CLIENT_ID="your_xero_client_id_here"
XERO_CLIENT_SECRET="your_xero_client_secret_here"
XERO_REDIRECT_URI="http://localhost:8000/api/v1/integrations/xero/callback"
XERO_SCOPES="openid profile email accounting.transactions accounting.contacts offline_access"

# Populated automatically after the OAuth2 callback; or set manually for testing
XERO_ACCESS_TOKEN=
XERO_REFRESH_TOKEN=
XERO_TENANT_ID=

# ------------------------------------------------------------------------------
# Database
# Example: postgresql+asyncpg://user:password@localhost:5432/bookkeeping_db
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost/bookkeeping

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL="INFO"    # DEBUG | INFO | WARNING | ERROR | CRITICAL
